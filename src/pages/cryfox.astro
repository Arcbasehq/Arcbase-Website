---
import Layout from "../layouts/Layout.astro";
import StarButton from "../components/StarButton.astro";
---

<Layout
    title="CryFox — Private, Secure, Fast Browser"
    description="CryFox removes telemetry, blocks tracking, isolates sessions, and is built for speed, privacy, and security."
    keywords="CryFox, privacy browser, secure browser, Firefox fork, tracker blocking, fingerprint protection"
    activePage="projects"
    ogType="article"
>
    <section class="page-hero">
        <div class="page-hero-content">
            <h1><span class="highlight">CryFox</span></h1>
            <p>Browse privately, faster.</p>
            <br />
            <div class="cryfox-hero-actions">
                <a href="#features" class="btn-secondary">See Features</a>
                <a
                    href="https://github.com/arcbasehq/cryfoxgecko"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">Source Code</a
                >
            </div>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <div class="about-grid">
                <div class="fade-up">
                    <div class="section-number">About</div>
                    <h2 class="section-title">Privacy without compromise</h2>
                    <p class="section-desc">
                        CryFox removes the telemetry, slashes tracking requests,
                        and isolates every session so your research stays yours.
                        Built for speed, tuned for privacy, hardened for
                        security.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="about-card">
                        <div class="about-stats">
                            <div class="stat-item">
                                <div class="stat-number">0</div>
                                <div class="stat-label">Telemetry</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">100%</div>
                                <div class="stat-label">Private</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">3x</div>
                                <div class="stat-label">Faster</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">100%</div>
                                <div class="stat-label">Open Source</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt" id="features">
        <div class="section-container">
            <div class="section-number fade-up">Why CryFox</div>
            <h2 class="section-title fade-up">
                Purpose-built controls, zero-leak policy
            </h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Your browser knows everything. CryFox ensures it stays that way.
            </p>

            <div class="cryfox-features-grid">
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"
                            ></line>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Zero Telemetry</h3>
                        <p>
                            No remote experiments, analytics, or surprise pings.
                            What runs on your machine is the code you installed.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Fingerprint Defense</h3>
                        <p>
                            Protects against canvas, audio, font, and hardware
                            fingerprinting out of the box.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect
                                x="3"
                                y="11"
                                width="18"
                                height="11"
                                rx="2"
                                ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Isolated Workspaces</h3>
                        <p>
                            Split workspaces, personas, and tab groups into
                            fully isolated sandboxes.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <polygon
                                points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                            ></polygon>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Oblivious DNS</h3>
                        <p>
                            Encrypted, anonymized DNS routing to keep lookups
                            unlinked from you.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <div class="section-number fade-up">Security</div>
            <h2 class="section-title fade-up">
                Built for people who take security seriously
            </h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Every workspace is isolated, extension access is scoped, and
                updates are signed and verified.
            </p>

            <div class="cryfox-features-grid">
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect
                                x="3"
                                y="3"
                                width="18"
                                height="18"
                                rx="2"
                                ry="2"></rect>
                            <path d="M3 9h18"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Per-workspace Storage</h3>
                        <p>
                            Separate storage keys and cookie boundaries for each
                            workspace.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                            <path d="M9 12l2 2 4-4"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Signed Updates</h3>
                        <p>Signed update chain with rollback protection.</p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                            ></path>
                            <path d="M14 2v6h6"></path>
                            <path d="M16 13H8"></path>
                            <path d="M16 17H8"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Policy Packs</h3>
                        <p>
                            Team-wide configuration with extension allowlists
                            and DNS rules.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 8v4"></path>
                            <path d="M12 16h.01"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Expiring Permissions</h3>
                        <p>Site permissions that expire automatically.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <div class="section-number fade-up">Performance</div>
            <h2 class="section-title fade-up">
                Fast by design, not by accident
            </h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Lean rendering, memory pressure guards, and optimized caching
                keep CryFox quick.
            </p>

            <div class="cryfox-features-grid">
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <polygon
                                points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                            ></polygon>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Smart Cache Warming</h3>
                        <p>
                            Privacy-aware prefetching that doesn't leak your
                            interests.
                        </p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M18 6L6 18M6 6l12 12"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Tab Hibernation</h3>
                        <p>Save memory by hibernating idle sessions.</p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect
                                x="4"
                                y="4"
                                width="16"
                                height="16"
                                rx="2"
                                ry="2"></rect>
                            <path d="M9 9h6v6H9z"></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>GPU-first Rendering</h3>
                        <p>Optimized for modern hardware acceleration.</p>
                    </div>
                </div>

                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg>
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Private Tabs</h3>
                        <p>Private browsing without slowing your session.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block" id="use-cases">
        <div class="section-container">
            <div class="section-number fade-up">Use Cases</div>
            <h2 class="section-title fade-up">For power users</h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Speed, privacy, and security for sensitive workflows.
            </p>

            <div class="cryfox-features-grid">
                <div class="cryfox-feature fade-up">
                    <h3>Incident Response</h3>
                    <p>
                        Investigate breaches without contaminating your main
                        browsing environment.
                    </p>
                </div>
                <div class="cryfox-feature fade-up">
                    <h3>Competitive Research</h3>
                    <p>
                        Research competitors without leaking your intent or
                        interests.
                    </p>
                </div>
                <div class="cryfox-feature fade-up">
                    <h3>Founder Mode</h3>
                    <p>
                        Build in privacy. Your ideas stay yours until you're
                        ready to share.
                    </p>
                </div>
                <div class="cryfox-feature fade-up">
                    <h3>Zero-trust Workflows</h3>
                    <p>Operate in hostile environments with full isolation.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt" style="text-align: center;">
        <div class="section-container fade-up">
            <h2 class="section-title">Ready to take back your browsing?</h2>
            <p class="section-desc" style="margin: 0 auto 24px;">
                Download CryFox, enable your policy set, and get a private
                browsing environment in minutes.
            </p>
            <div
                style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; align-items: center;"
            >
                <a
                    href="https://github.com/arcbasehq/cryfoxgecko"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">View on GitHub</a
                >
                <a href="/projects" class="btn-secondary">All Projects</a>
                <StarButton projectId="cryfox" projectName="CryFox" />
            </div>
        </div>
    </section>

    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "CryFox",
            applicationCategory: "WebBrowser",
            operatingSystem: "Windows, macOS, Linux",
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "USD",
            },
            description:
                "Private, secure, fast browser with zero telemetry and fingerprint defense.",
            author: {
                "@type": "Organization",
                name: "arcbase",
            },
        })}
    />
</Layout>

<style>
    .cryfox-hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .cryfox-features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    .cryfox-feature {
        display: flex;
        gap: 16px;
        padding: 24px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }

    .cryfox-feature-icon {
        width: 44px;
        height: 44px;
        flex-shrink: 0;
        background: var(--accent-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
    }

    .cryfox-feature-text h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .cryfox-feature-text p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    @media (max-width: 768px) {
        .cryfox-features-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
