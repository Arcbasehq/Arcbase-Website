---
// ConvexClientProvider.astro
---

<div id="convex-provider">
    <slot />
</div>

<script>
    import { ConvexClient } from "convex/browser";
    
    const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;
    if (!convexUrl) {
        console.error("Missing PUBLIC_CONVEX_URL environment variable");
    }

    // Create Convex client
    const convex = new ConvexClient(convexUrl || "");

    // Debug: log presence of stored token (do not print token value)
    try {
        const storedToken = localStorage.getItem('convex_auth_token');
        console.debug('ConvexClientProvider: PUBLIC_CONVEX_URL=', convexUrl);
        console.debug('ConvexClientProvider: stored token present=', !!storedToken);
        if (storedToken) {
            convex.setAuth(() => Promise.resolve(storedToken));
        }
    } catch (e) {
        console.warn('ConvexClientProvider: could not access localStorage', e);
    }

    // Expose Convex client and connection state for debugging
    try {
        (window as any).__convex = convex;
        if (typeof convex.subscribeToConnectionState === 'function') {
            convex.subscribeToConnectionState((state) => {
                console.debug('Convex connection state:', state);
            });
        } else if (typeof convex.connectionState === 'function') {
            // Fallback: log initial connection state
            console.debug('Convex initial connection state:', convex.connectionState());
        }
    } catch (e) {
        console.error('ConvexClientProvider: error exposing client for debug', e);
    }
</script>
