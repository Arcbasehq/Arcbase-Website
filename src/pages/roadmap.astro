---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Roadmap"
    description="arcbase Roadmap - Software ideas you'll actually use"
    activePage="roadmap"
>
    <section class="page-hero">
        <div class="page-hero-content fade-up">
            <h1>Roadmap</h1>
            <p>Software ideas you'll actually use</p>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <div class="roadmap-timeline">
                <div class="roadmap-phase fade-up">
                    <div class="phase-tag shipped">Shipped ✓</div>
                    <h2>Shipped</h2>
                    <p>Released and available to use today.</p>

                    <div class="roadmap-items">
                        <div class="roadmap-item shipped-item">
                            <div class="item-icon shipped-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <rect
                                        x="2"
                                        y="3"
                                        width="20"
                                        height="14"
                                        rx="2"
                                        ry="2"></rect>
                                    <line x1="8" y1="21" x2="16" y2="21"></line>
                                    <line x1="12" y1="17" x2="12" y2="21"
                                    ></line>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>
                                    ArcOS <span class="shipped-check">✓</span>
                                </h3>
                                <p>
                                    Optimized, bloat-free Windows 11 for
                                    developers and power users. Privacy-focused
                                    and performance-tuned.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item shipped-item">
                            <div class="item-icon shipped-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"
                                    ></line>
                                    <path
                                        d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                                    ></path>
                                    <polyline
                                        points="3.27 6.96 12 12.01 20.73 6.96"
                                    ></polyline>
                                    <line x1="12" y1="22.08" x2="12" y2="12"
                                    ></line>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>
                                    Arc Manager <span class="shipped-check"
                                        >✓</span>
                                </h3>
                                <p>
                                    Unified Linux package manager frontend for
                                    pacman, apt, dnf, and the AUR under one
                                    interface.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item shipped-item">
                            <div class="item-icon shipped-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"
                                    ></path>
                                    <path
                                        d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20"
                                    ></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>
                                    OpenShelf <span class="shipped-check"
                                        >✓</span>
                                </h3>
                                <p>
                                    Privacy-focused open source library for
                                    cataloging your digital book and media
                                    collections.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item shipped-item">
                            <div class="item-icon shipped-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="2" y1="12" x2="22" y2="12"></line>
                                    <path
                                        d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>
                                    CryFox <span class="shipped-check">✓</span>
                                </h3>
                                <p>
                                    Privacy-first Firefox fork with telemetry
                                    stripped, tracker blocking, and fingerprint
                                    resistance baked in.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="roadmap-phase fade-up">
                    <div class="phase-tag">Now</div>
                    <h2>In Development</h2>
                    <p>What we're building right now.</p>

                    <div class="roadmap-items">
                        <div class="roadmap-item">
                            <div class="item-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <rect
                                        x="3"
                                        y="11"
                                        width="18"
                                        height="11"
                                        rx="2"
                                        ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>CryFox</h3>
                                <p>
                                    Firefox fork that removes telemetry, blocks
                                    trackers, and resists fingerprinting.
                                    Privacy by default.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item">
                            <div class="item-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>Sentinel</h3>
                                <p>
                                    File integrity and anomaly detection for
                                    Linux servers. Detect intrusions fast.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="roadmap-phase fade-up">
                    <div class="phase-tag">Later</div>
                    <h2>Considering</h2>
                    <p>Ideas we're exploring. Vote with your feedback.</p>

                    <div class="roadmap-items">
                        <div class="roadmap-item">
                            <div class="item-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path
                                        d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24"
                                    ></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>Loggly Alternative</h3>
                                <p>
                                    Simple log management. Ship logs, search
                                    them, set alerts.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item">
                            <div class="item-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>Uptime Monitor</h3>
                                <p>
                                    Simple service monitoring. Get alerted when
                                    your sites go down. Email and webhook
                                    notifications.
                                </p>
                            </div>
                        </div>

                        <div class="roadmap-item">
                            <div class="item-icon">
                                <svg
                                    viewBox="0 0 24 24"
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                                    ></path>
                                    <path d="M14 2v6h6"></path>
                                    <path d="M16 13H8"></path>
                                    <path d="M16 17H8"></path>
                                </svg>
                            </div>
                            <div class="item-content">
                                <h3>paste.arcbase.one</h3>
                                <p>
                                    Ad-free pastebin. No tracking, no signup,
                                    Like pastebin but works.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container" style="text-align: center;">
            <h2 class="fade-up">Have an idea?</h2>
            <p class="section-desc fade-up" style="margin: 0 auto 24px;">
                Tell us what tools would actually help you.
            </p>
            <a
                href="mailto:arcbase@tuta.io?subject=Roadmap idea"
                class="btn-primary fade-up">Share Your Idea</a
            >
        </div>
    </section>
</Layout>

<style>
    .roadmap-timeline {
        max-width: 800px;
        margin: 0 auto;
    }

    .roadmap-phase {
        margin-bottom: 48px;
    }

    .phase-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 12px;
    }

    .roadmap-phase:first-child .phase-tag.shipped {
        background: #dcfce7;
        color: #16a34a;
    }

    .roadmap-phase:nth-child(2) .phase-tag {
        background: var(--accent-light);
        color: var(--accent);
    }

    .roadmap-phase:nth-child(3) .phase-tag {
        background: #fef3c7;
        color: #d97706;
    }

    .shipped-item {
        opacity: 0.85;
    }

    .shipped-icon {
        background: #dcfce7 !important;
        color: #16a34a !important;
    }

    .shipped-check {
        color: #16a34a;
        font-size: 0.875rem;
    }

    .roadmap-phase h2 {
        font-family: var(--font-branding);
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .roadmap-phase > p {
        color: var(--text-secondary);
        margin-bottom: 24px;
    }

    .roadmap-items {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .roadmap-item {
        display: flex;
        gap: 16px;
        padding: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }

    .item-icon {
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        background: var(--accent-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
    }

    .item-content h3 {
        font-family: var(--font-branding);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .item-content p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin: 0;
    }

    @media (max-width: 640px) {
        .roadmap-item {
            flex-direction: column;
            gap: 12px;
        }
    }
</style>
